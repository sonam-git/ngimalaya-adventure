# Email Configuration
# ==================
# Choose email provider: 'nodemailer' (default) or 'sendgrid'
EMAIL_PROVIDER=nodemailer

# Destination email for form submissions
NGIMALAYA_EMAIL=your_email@example.com

# ===================
# SMTP Configuration (for Nodemailer)
# ===================
# For Gmail SMTP:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use that App Password as SMTP_PASS

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ===================
# SendGrid Configuration (legacy/fallback)
# ===================
# Set EMAIL_PROVIDER=sendgrid to use SendGrid instead
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
